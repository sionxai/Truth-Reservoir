{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truthreservoir.example/api/v2/schema/institutional-metrics.schema.json",
  "type": "object",
  "properties": {
    "totalEntries": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "totalAssessed": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "totalUndetermined": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "totalRetracted": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "measuredErrorRate": {
      "type": "object",
      "properties": {
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "unit": {
          "type": "string",
          "const": "ratio"
        },
        "sampleSize": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "periodStart": {
          "type": "string"
        },
        "periodEnd": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "measured",
            "unmeasured_insufficient_sample"
          ]
        }
      },
      "required": [
        "value",
        "unit",
        "sampleSize",
        "periodStart",
        "periodEnd",
        "method",
        "status"
      ],
      "additionalProperties": false
    },
    "correctionMetrics": {
      "type": "object",
      "properties": {
        "openCorrectionRequests": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "acceptedCorrections": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "rejectedCorrections": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "staleCorrectionRequests": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "medianCorrectionLatencyDays": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "latencyStatus": {
          "type": "string",
          "enum": [
            "measured",
            "no_requests_yet"
          ]
        },
        "staleThresholdDays": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "openCorrectionRequests",
        "acceptedCorrections",
        "rejectedCorrections",
        "staleCorrectionRequests",
        "medianCorrectionLatencyDays",
        "latencyStatus",
        "staleThresholdDays"
      ],
      "additionalProperties": false
    },
    "externalAudits": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "auditor": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "reportUrl": {
            "type": "string",
            "format": "uri"
          },
          "sampleSize": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          "findingsSummary": {
            "type": "string"
          }
        },
        "required": [
          "auditor",
          "date",
          "reportUrl",
          "sampleSize",
          "findingsSummary"
        ],
        "additionalProperties": false
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "established",
        "unestablished"
      ]
    }
  },
  "required": [
    "totalEntries",
    "totalAssessed",
    "totalUndetermined",
    "totalRetracted",
    "measuredErrorRate",
    "correctionMetrics",
    "externalAudits",
    "status"
  ],
  "additionalProperties": false
}
