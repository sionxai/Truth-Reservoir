{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truthreservoir.example/api/v2/schema/cert-v2.schema.json",
  "type": "object",
  "properties": {
    "certVersion": {
      "type": "string",
      "const": "2.1"
    },
    "propositionId": {
      "type": "string",
      "pattern": "^stmt:[a-f0-9]{24}$"
    },
    "versionId": {
      "type": "string",
      "pattern": "^ver:[a-f0-9]{16}$"
    },
    "certHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "previousVersionId": {
      "type": "string",
      "pattern": "^ver:[a-f0-9]{16}$"
    },
    "canonicalProposition": {
      "type": "string",
      "minLength": 10,
      "maxLength": 300
    },
    "originalClaim": {
      "type": "string"
    },
    "claimNature": {
      "type": "string",
      "enum": [
        "event_occurrence",
        "document_content",
        "measurement"
      ]
    },
    "measurement": {
      "type": "object",
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "sample": {
          "type": "string",
          "minLength": 1
        },
        "aggregationBasis": {
          "type": "string",
          "minLength": 1
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "measuredAt": {
          "type": "string"
        }
      },
      "required": [
        "method",
        "sample",
        "aggregationBasis",
        "producer"
      ],
      "additionalProperties": false
    },
    "sixW": {
      "type": "object",
      "properties": {
        "who": {
          "type": "string",
          "minLength": 1
        },
        "when": {
          "type": "string",
          "minLength": 1
        },
        "where": {
          "type": "string",
          "minLength": 1
        },
        "what": {
          "type": "string",
          "minLength": 1
        },
        "how": {
          "type": "string",
          "minLength": 1
        },
        "why": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "reason": {
                "type": "string",
                "minLength": 1
              },
              "statedBy": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "reason",
              "statedBy"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "who",
        "when",
        "where",
        "what",
        "how",
        "why"
      ],
      "additionalProperties": false
    },
    "classification": {
      "type": "string",
      "enum": [
        "F",
        "O",
        "M"
      ]
    },
    "language": {
      "type": "string",
      "enum": [
        "ko",
        "en"
      ]
    },
    "asOfDate": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "superseded",
        "retracted",
        "needs_review"
      ]
    },
    "reviewMode": {
      "default": "human_reviewed",
      "type": "string",
      "enum": [
        "human_reviewed",
        "automated_unreviewed"
      ]
    },
    "assessment": {
      "type": "object",
      "properties": {
        "factualGrade": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "fully_reliable",
                "largely_reliable",
                "mixed",
                "largely_unreliable",
                "not_reliable"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "assessed",
            "undetermined"
          ]
        },
        "gradeRationale": {
          "type": "string",
          "minLength": 1
        },
        "rubricVersion": {
          "type": "string",
          "minLength": 1
        },
        "pipelineVersion": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "factualGrade",
        "status",
        "gradeRationale",
        "rubricVersion",
        "pipelineVersion"
      ],
      "additionalProperties": false
    },
    "evidence": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "retrievedAt": {
            "type": "string"
          },
          "locator": {
            "type": "object",
            "properties": {
              "section": {
                "type": "string"
              },
              "heading": {
                "type": "string"
              },
              "page": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "shortQuote": {
            "type": "string",
            "minLength": 1
          },
          "quoteHash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "archiveStatus": {
            "type": "string",
            "enum": [
              "archived",
              "archive_attempt_recommended",
              "not_required_stable_artifact",
              "unavailable"
            ]
          },
          "archiveUrl": {
            "type": "string",
            "format": "uri"
          },
          "archiveProvider": {
            "type": "string",
            "enum": [
              "internet_archive",
              "perma",
              "manual_pdf",
              "repository",
              "other"
            ]
          },
          "archivedAt": {
            "type": "string"
          },
          "retrievalMethod": {
            "type": "string",
            "enum": [
              "manual",
              "crawler",
              "pdf_extract",
              "api",
              "official_gazette",
              "court_document"
            ]
          },
          "retrievalLimitations": {
            "type": "string"
          },
          "independenceGroupId": {
            "type": "string",
            "minLength": 1
          },
          "independenceLevel": {
            "type": "string",
            "enum": [
              "independent",
              "partially_independent",
              "shared_origin",
              "unknown"
            ]
          },
          "independenceNote": {
            "type": "string"
          },
          "sourceCompetence": {
            "type": "string",
            "enum": [
              "domain_expert",
              "relevant",
              "tangential",
              "unqualified"
            ]
          },
          "competenceNote": {
            "type": "string"
          },
          "sourceType": {
            "type": "string",
            "enum": [
              "primary_producer",
              "secondary_report",
              "aggregator"
            ]
          },
          "sourceProvenance": {
            "type": "object",
            "properties": {
              "productionIndependence": {
                "type": "string",
                "enum": [
                  "independent",
                  "govt_produced",
                  "party_interested",
                  "contested"
                ]
              },
              "productionConcerns": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "requiresMethodologyAudit": {
                "type": "boolean"
              }
            },
            "required": [
              "productionIndependence",
              "productionConcerns",
              "requiresMethodologyAudit"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "url",
          "title",
          "retrievedAt",
          "shortQuote",
          "quoteHash",
          "archiveStatus",
          "retrievalMethod",
          "retrievalLimitations",
          "independenceGroupId",
          "independenceLevel",
          "independenceNote",
          "sourceCompetence",
          "competenceNote",
          "sourceType",
          "sourceProvenance"
        ],
        "additionalProperties": false
      }
    },
    "reviewLog": {
      "type": "object",
      "properties": {
        "redteam": {
          "type": "object",
          "properties": {
            "strongestCounterargument": {
              "type": "string"
            },
            "response": {
              "type": "string"
            },
            "errorsFound": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "framingChecks": {
              "type": "string"
            }
          },
          "required": [
            "strongestCounterargument",
            "response",
            "errorsFound",
            "framingChecks"
          ],
          "additionalProperties": false
        },
        "symmetry": {
          "type": "object",
          "properties": {
            "checked": {
              "type": "boolean"
            },
            "method": {
              "type": "string"
            },
            "pairedPropositionId": {
              "type": "string",
              "pattern": "^stmt:[a-f0-9]{24}$"
            },
            "result": {
              "type": "string"
            }
          },
          "required": [
            "checked",
            "method",
            "result"
          ],
          "additionalProperties": false
        },
        "authorityCheck": {
          "type": "object",
          "properties": {
            "checked": {
              "type": "boolean"
            },
            "note": {
              "type": "string"
            }
          },
          "required": [
            "checked",
            "note"
          ],
          "additionalProperties": false
        },
        "humanReview": {
          "type": "object",
          "properties": {
            "reviewer": {
              "type": "string"
            },
            "date": {
              "type": "string"
            },
            "checksPerformed": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "omission",
                  "asymmetry",
                  "framing",
                  "authority_assumption"
                ]
              }
            },
            "reviewMemo": {
              "type": "string"
            },
            "adoptedReason": {
              "type": "string"
            },
            "rejectedAlternatives": {
              "type": "string"
            }
          },
          "required": [
            "reviewer",
            "date",
            "checksPerformed",
            "reviewMemo",
            "adoptedReason",
            "rejectedAlternatives"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "redteam",
        "symmetry",
        "authorityCheck",
        "humanReview"
      ],
      "additionalProperties": false
    },
    "sensitive": {
      "type": "object",
      "properties": {
        "sensitive": {
          "type": "boolean"
        },
        "sensitivityReason": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "living_person",
              "criminal_allegation",
              "ongoing_litigation",
              "political_claim",
              "medical_or_financial_harm",
              "demographic_identity",
              "scientific_contested"
            ]
          }
        },
        "legalStatus": {
          "type": "string",
          "enum": [
            "final_judgment",
            "pending",
            "allegation",
            "official_record",
            "unknown",
            "not_applicable"
          ]
        },
        "presumptionNotice": {
          "type": "string"
        }
      },
      "required": [
        "sensitive",
        "sensitivityReason",
        "legalStatus",
        "presumptionNotice"
      ],
      "additionalProperties": false
    },
    "undeterminedItems": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "correctionHistory": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string"
          },
          "error": {
            "type": "string"
          },
          "detectedBy": {
            "type": "string"
          },
          "before": {
            "type": "string"
          },
          "after": {
            "type": "string"
          },
          "scoreChange": {
            "type": "string"
          },
          "newVersionId": {
            "type": "string",
            "pattern": "^ver:[a-f0-9]{16}$"
          }
        },
        "required": [
          "date",
          "error",
          "detectedBy",
          "before",
          "after",
          "scoreChange",
          "newVersionId"
        ],
        "additionalProperties": false
      }
    },
    "openCorrectionRequests": {
      "default": 0,
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "limitations": {
      "type": "string"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    }
  },
  "required": [
    "certVersion",
    "propositionId",
    "versionId",
    "certHash",
    "canonicalProposition",
    "claimNature",
    "classification",
    "language",
    "asOfDate",
    "status",
    "reviewMode",
    "assessment",
    "evidence",
    "reviewLog",
    "sensitive",
    "undeterminedItems",
    "correctionHistory",
    "openCorrectionRequests",
    "limitations",
    "tags",
    "createdAt",
    "updatedAt"
  ],
  "additionalProperties": false
}
