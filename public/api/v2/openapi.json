{
  "openapi": "3.1.0",
  "info": {
    "title": "Truth Reservoir Cert API",
    "version": "2.0.0"
  },
  "paths": {
    "/api/v2/index.json": {
      "get": {
        "summary": "List published Cert v2 propositions",
        "responses": {
          "200": {
            "description": "Static proposition index: { data: CertV2[], meta }",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "data",
                    "meta"
                  ],
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/CertV2"
                      }
                    },
                    "meta": {
                      "type": "object",
                      "required": [
                        "total",
                        "dataVersion"
                      ],
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "dataVersion": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/propositions/{propositionId}.json": {
      "get": {
        "summary": "Fetch one Cert v2 proposition document",
        "parameters": [
          {
            "name": "propositionId",
            "in": "path",
            "required": true,
            "description": "propositionId with ':' encoded as '-' (e.g. stmt-840aa7c3...).",
            "schema": {
              "type": "string",
              "pattern": "^stmt-[a-f0-9]{24}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cert v2 proposition",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CertV2"
                }
              }
            }
          },
          "404": {
            "description": "Unknown proposition",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/schema/cert-v2.schema.json": {
      "get": {
        "summary": "JSON Schema (2020-12) for a Cert v2 proposition",
        "responses": {
          "200": {
            "description": "JSON Schema document"
          }
        }
      }
    },
    "/api/v2/openapi.json": {
      "get": {
        "summary": "This OpenAPI 3.1 document",
        "responses": {
          "200": {
            "description": "OpenAPI document"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CertV2": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://truthreservoir.example/api/v2/schema/cert-v2.schema.json",
        "type": "object",
        "properties": {
          "certVersion": {
            "type": "string",
            "const": "2.0"
          },
          "propositionId": {
            "type": "string",
            "pattern": "^stmt:[a-f0-9]{24}$"
          },
          "versionId": {
            "type": "string",
            "pattern": "^ver:[a-f0-9]{16}$"
          },
          "certHash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "previousVersionId": {
            "type": "string",
            "pattern": "^ver:[a-f0-9]{16}$"
          },
          "canonicalProposition": {
            "type": "string",
            "minLength": 10,
            "maxLength": 300
          },
          "originalClaim": {
            "type": "string"
          },
          "claimNature": {
            "type": "string",
            "enum": [
              "event_occurrence",
              "document_content",
              "measurement"
            ]
          },
          "measurement": {
            "type": "object",
            "properties": {
              "method": {
                "type": "string",
                "minLength": 1
              },
              "sample": {
                "type": "string",
                "minLength": 1
              },
              "aggregationBasis": {
                "type": "string",
                "minLength": 1
              },
              "producer": {
                "type": "string",
                "minLength": 1
              },
              "measuredAt": {
                "type": "string"
              }
            },
            "required": [
              "method",
              "sample",
              "aggregationBasis",
              "producer"
            ],
            "additionalProperties": false
          },
          "classification": {
            "type": "string",
            "enum": [
              "F",
              "O",
              "M"
            ]
          },
          "language": {
            "type": "string",
            "enum": [
              "ko",
              "en"
            ]
          },
          "asOfDate": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "superseded",
              "retracted",
              "needs_review"
            ]
          },
          "reviewMode": {
            "default": "human_reviewed",
            "type": "string",
            "enum": [
              "human_reviewed",
              "automated_unreviewed"
            ]
          },
          "assessment": {
            "type": "object",
            "properties": {
              "factualGrade": {
                "anyOf": [
                  {
                    "type": "string",
                    "enum": [
                      "fully_reliable",
                      "largely_reliable",
                      "mixed",
                      "largely_unreliable",
                      "not_reliable"
                    ]
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "status": {
                "type": "string",
                "enum": [
                  "assessed",
                  "undetermined"
                ]
              },
              "gradeRationale": {
                "type": "string",
                "minLength": 1
              },
              "rubricVersion": {
                "type": "string",
                "minLength": 1
              },
              "pipelineVersion": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "factualGrade",
              "status",
              "gradeRationale",
              "rubricVersion",
              "pipelineVersion"
            ],
            "additionalProperties": false
          },
          "evidence": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string",
                  "format": "uri"
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "retrievedAt": {
                  "type": "string"
                },
                "evidenceSpans": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "start": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      },
                      "end": {
                        "type": "integer",
                        "minimum": -9007199254740991,
                        "maximum": 9007199254740991
                      }
                    },
                    "required": [
                      "start",
                      "end"
                    ],
                    "additionalProperties": false
                  }
                },
                "spanHash": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "shortQuote": {
                  "type": "string",
                  "minLength": 1
                },
                "archiveUrl": {
                  "type": "string",
                  "format": "uri"
                },
                "archiveProvider": {
                  "type": "string",
                  "enum": [
                    "internet_archive",
                    "perma",
                    "manual_pdf",
                    "repository",
                    "other"
                  ]
                },
                "archivedAt": {
                  "type": "string"
                },
                "retrievalMethod": {
                  "type": "string",
                  "enum": [
                    "manual",
                    "crawler",
                    "pdf_extract",
                    "api",
                    "official_gazette",
                    "court_document"
                  ]
                },
                "retrievalLimitations": {
                  "type": "string"
                },
                "independenceGroupId": {
                  "type": "string",
                  "minLength": 1
                },
                "independenceLevel": {
                  "type": "string",
                  "enum": [
                    "independent",
                    "partially_independent",
                    "shared_origin",
                    "unknown"
                  ]
                },
                "independenceNote": {
                  "type": "string"
                },
                "sourceCompetence": {
                  "type": "string",
                  "enum": [
                    "domain_expert",
                    "relevant",
                    "tangential",
                    "unqualified"
                  ]
                },
                "competenceNote": {
                  "type": "string"
                },
                "sourceType": {
                  "type": "string",
                  "enum": [
                    "primary_producer",
                    "secondary_report",
                    "aggregator"
                  ]
                },
                "sourceProvenance": {
                  "type": "object",
                  "properties": {
                    "productionIndependence": {
                      "type": "string",
                      "enum": [
                        "independent",
                        "govt_produced",
                        "party_interested",
                        "contested"
                      ]
                    },
                    "productionConcerns": {
                      "default": [],
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "requiresMethodologyAudit": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "productionIndependence",
                    "productionConcerns",
                    "requiresMethodologyAudit"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "url",
                "title",
                "retrievedAt",
                "evidenceSpans",
                "spanHash",
                "retrievalMethod",
                "retrievalLimitations",
                "independenceGroupId",
                "independenceLevel",
                "independenceNote",
                "sourceCompetence",
                "competenceNote",
                "sourceType",
                "sourceProvenance"
              ],
              "additionalProperties": false
            }
          },
          "reviewLog": {
            "type": "object",
            "properties": {
              "redteam": {
                "type": "object",
                "properties": {
                  "strongestCounterargument": {
                    "type": "string"
                  },
                  "response": {
                    "type": "string"
                  },
                  "errorsFound": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "framingChecks": {
                    "type": "string"
                  }
                },
                "required": [
                  "strongestCounterargument",
                  "response",
                  "errorsFound",
                  "framingChecks"
                ],
                "additionalProperties": false
              },
              "symmetry": {
                "type": "object",
                "properties": {
                  "checked": {
                    "type": "boolean"
                  },
                  "method": {
                    "type": "string"
                  },
                  "pairedPropositionId": {
                    "type": "string",
                    "pattern": "^stmt:[a-f0-9]{24}$"
                  },
                  "result": {
                    "type": "string"
                  }
                },
                "required": [
                  "checked",
                  "method",
                  "result"
                ],
                "additionalProperties": false
              },
              "authorityCheck": {
                "type": "object",
                "properties": {
                  "checked": {
                    "type": "boolean"
                  },
                  "note": {
                    "type": "string"
                  }
                },
                "required": [
                  "checked",
                  "note"
                ],
                "additionalProperties": false
              },
              "humanReview": {
                "type": "object",
                "properties": {
                  "reviewer": {
                    "type": "string"
                  },
                  "date": {
                    "type": "string"
                  },
                  "checksPerformed": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "omission",
                        "asymmetry",
                        "framing",
                        "authority_assumption"
                      ]
                    }
                  },
                  "reviewMemo": {
                    "type": "string"
                  },
                  "adoptedReason": {
                    "type": "string"
                  },
                  "rejectedAlternatives": {
                    "type": "string"
                  }
                },
                "required": [
                  "reviewer",
                  "date",
                  "checksPerformed",
                  "reviewMemo",
                  "adoptedReason",
                  "rejectedAlternatives"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "redteam",
              "symmetry",
              "authorityCheck",
              "humanReview"
            ],
            "additionalProperties": false
          },
          "sensitive": {
            "type": "object",
            "properties": {
              "sensitive": {
                "type": "boolean"
              },
              "sensitivityReason": {
                "default": [],
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "living_person",
                    "criminal_allegation",
                    "ongoing_litigation",
                    "political_claim",
                    "medical_or_financial_harm"
                  ]
                }
              },
              "legalStatus": {
                "type": "string",
                "enum": [
                  "final_judgment",
                  "pending",
                  "allegation",
                  "official_record",
                  "unknown"
                ]
              },
              "presumptionNotice": {
                "type": "string"
              }
            },
            "required": [
              "sensitive",
              "sensitivityReason",
              "legalStatus",
              "presumptionNotice"
            ],
            "additionalProperties": false
          },
          "undeterminedItems": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "correctionHistory": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string"
                },
                "error": {
                  "type": "string"
                },
                "detectedBy": {
                  "type": "string"
                },
                "before": {
                  "type": "string"
                },
                "after": {
                  "type": "string"
                },
                "scoreChange": {
                  "type": "string"
                },
                "newVersionId": {
                  "type": "string",
                  "pattern": "^ver:[a-f0-9]{16}$"
                }
              },
              "required": [
                "date",
                "error",
                "detectedBy",
                "before",
                "after",
                "scoreChange",
                "newVersionId"
              ],
              "additionalProperties": false
            }
          },
          "openCorrectionRequests": {
            "default": 0,
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "limitations": {
            "type": "string"
          },
          "tags": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "certVersion",
          "propositionId",
          "versionId",
          "certHash",
          "canonicalProposition",
          "claimNature",
          "classification",
          "language",
          "asOfDate",
          "status",
          "reviewMode",
          "assessment",
          "evidence",
          "reviewLog",
          "sensitive",
          "undeterminedItems",
          "correctionHistory",
          "openCorrectionRequests",
          "limitations",
          "tags",
          "createdAt",
          "updatedAt"
        ],
        "additionalProperties": false
      },
      "InstitutionalMetrics": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://truthreservoir.example/api/v2/schema/institutional-metrics.schema.json",
        "type": "object",
        "properties": {
          "totalEntries": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "totalAssessed": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "totalUndetermined": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "totalRetracted": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "measuredErrorRate": {
            "type": "object",
            "properties": {
              "value": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "unit": {
                "type": "string",
                "const": "ratio"
              },
              "sampleSize": {
                "type": "integer",
                "minimum": -9007199254740991,
                "maximum": 9007199254740991
              },
              "periodStart": {
                "type": "string"
              },
              "periodEnd": {
                "type": "string"
              },
              "method": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "measured",
                  "unmeasured_insufficient_sample"
                ]
              }
            },
            "required": [
              "value",
              "unit",
              "sampleSize",
              "periodStart",
              "periodEnd",
              "method",
              "status"
            ],
            "additionalProperties": false
          },
          "correctionMetrics": {
            "type": "object",
            "properties": {
              "openCorrectionRequests": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "acceptedCorrections": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "rejectedCorrections": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "staleCorrectionRequests": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "medianCorrectionLatencyDays": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "latencyStatus": {
                "type": "string",
                "enum": [
                  "measured",
                  "no_requests_yet"
                ]
              },
              "staleThresholdDays": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "openCorrectionRequests",
              "acceptedCorrections",
              "rejectedCorrections",
              "staleCorrectionRequests",
              "medianCorrectionLatencyDays",
              "latencyStatus",
              "staleThresholdDays"
            ],
            "additionalProperties": false
          },
          "externalAudits": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "auditor": {
                  "type": "string"
                },
                "date": {
                  "type": "string"
                },
                "reportUrl": {
                  "type": "string",
                  "format": "uri"
                },
                "sampleSize": {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "findingsSummary": {
                  "type": "string"
                }
              },
              "required": [
                "auditor",
                "date",
                "reportUrl",
                "sampleSize",
                "findingsSummary"
              ],
              "additionalProperties": false
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "established",
              "unestablished"
            ]
          }
        },
        "required": [
          "totalEntries",
          "totalAssessed",
          "totalUndetermined",
          "totalRetracted",
          "measuredErrorRate",
          "correctionMetrics",
          "externalAudits",
          "status"
        ],
        "additionalProperties": false
      },
      "ApiError": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "object",
            "required": [
              "code",
              "message"
            ],
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "NOT_FOUND",
                  "VALIDATION_ERROR",
                  "INTERNAL_ERROR"
                ]
              },
              "message": {
                "type": "string"
              },
              "fields": {
                "type": "object"
              }
            }
          }
        }
      }
    }
  }
}
